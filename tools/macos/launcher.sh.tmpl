#!/bin/bash
# Astro-Nex launcher (hybrid bundle).
#
# The .app embeds the astronex package + this launcher + the icon + Info.plist.
# Python and the GTK/cairo dylibs are resolved from the system/Homebrew at
# runtime via DYLD/GI env. This makes the .app small and robust (no fragile
# dylib-path rewriting or framework-Python bundling) at the cost of requiring
# Homebrew + the GTK stack installed on the target Mac.
#
# For a fully self-contained bundle (no Homebrew dependency), see the spec's
# "embedded" approach — deferred pending a standalone-Python resolution.
#
# Variables substituted at build time: {{PY_BIN}} {{ASTRONEX_DIR}} {{VERSION}}

set -e

# --- resolve bundle paths (relocatable) ---
HERE="$(cd "$(dirname "$0")" && pwd)"            # .../Contents/MacOS
CONTENTS="$(dirname "$HERE")"
RESOURCES="$CONTENTS/Resources"

# --- locate Homebrew prefix (arm64 or intel) ---
if [ -x /opt/homebrew/bin/python3 ]; then
    BREW=/opt/homebrew
else
    BREW=/usr/local
fi
PY_BIN="{{PY_BIN}}"                              # /opt/homebrew/bin/python3.14

# --- point Python at the embedded astronex package.
# PYTHONPATH is the PARENT of the astronex package dir, so `python -m astronex`
# resolves astronex as an importable package. ---
export PYTHONPATH="$RESOURCES"

# --- isolate GTK/GI env to Homebrew (so the app finds typelibs/loaders) ---
export GI_TYPELIB_PATH="$BREW/lib/girepository-1.0"
export GDK_PIXBUF_MODULE_FILE="$BREW/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export XDG_DATA_DIRS="$BREW/share"
export LANG="${LANG:-en_US.UTF-8}"

# --- single instance (avoid duplicate windows on rapid double-click) ---
LOCK="/tmp/astro-nex.lock"
if [ -e "$LOCK" ] && kill -0 "$(cat "$LOCK")" 2>/dev/null; then
    exit 0
fi
echo $$ > "$LOCK"
trap 'rm -f "$LOCK"' EXIT

# --- run with self-diagnosis ---
LOG_DIR="$HOME/Library/Logs/Astro-Nex"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/app.log"

if "$PY_BIN" -m astronex >"$LOG" 2>&1; then
    exit 0
fi

# --- failure path: native dialog with the error tail, never crash silent ---
RC=$?
ERR="$(tail -n 20 "$LOG" 2>/dev/null)"
osascript -e "display dialog \"Astro-Nex failed to start (exit $RC). See the log at:\\n$LOG\\n\\n$ERR\" with title \"Astro-Nex\" buttons {\"OK\"} default button 1 with icon stop" >/dev/null 2>&1 || true
exit $RC
