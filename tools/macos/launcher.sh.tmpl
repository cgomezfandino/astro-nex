#!/bin/bash
# Astro-Nex launcher — fixes the GTK/Python environment to bundle-relative
# paths, then runs the embedded interpreter. Self-diagnoses on failure.
#
# Generated from launcher.sh.tmpl by tools/build_macos_app.py.
# Variables substituted at build time: {{PY_BIN}} {{PY_HOME}} {{LIB_DIR}}
# {{GI_TYPELIB_DIR}} {{GDK_PIXBUF_MODFILE}} {{GTK_SCHEMAS_DIR}}

set -e

# --- resolve bundle paths (relocatable: works from /Applications or anywhere) ---
HERE="$(cd "$(dirname "$0")" && pwd)"            # .../Contents/MacOS
CONTENTS="$(dirname "$HERE")"
RESOURCES="$CONTENTS/Resources"
BIN_DIR="{{BIN_DIR}}"                              # .../Contents/MacOS/Astro-Nex.bin
PY_BIN="$BIN_DIR/{{PY_BIN}}"
PY_HOME="$BIN_DIR/{{PY_HOME}}"
LIB_DIR="$BIN_DIR/lib"

# --- isolate the runtime environment to the bundle (no /opt/homebrew leaks) ---
export DYLD_LIBRARY_PATH="$LIB_DIR"
export DYLD_FALLBACK_LIBRARY_PATH="$LIB_DIR"
export GI_TYPELIB_PATH="$LIB_DIR/girepository-1.0"
export GDK_PIXBUF_MODULE_FILE="$LIB_DIR/gdk-pixbuf-2.0/loaders.cache"
export GTK_PATH=""
export GTK_IM_MODULE_FILE=""
export XDG_DATA_DIRS="$LIB_DIR/share"
export GDK_PIXBUF_PIXDATA="$LIB_DIR/gdk-pixbuf-2.0"
export FONTCONFIG_PATH="$LIB_DIR/etc/fonts"
export LANG="${LANG:-en_US.UTF-8}"

# Python: point the embedded interpreter at its bundle-relative stdlib.
export PYTHONHOME="$PY_HOME"
export PYTHONPATH="$PY_HOME/lib/python{{PY_VER}}/site-packages"

# --- single instance (avoid duplicate windows on rapid double-click) ---
LOCK="/tmp/astro-nex.lock"
if [ -e "$LOCK" ] && kill -0 "$(cat "$LOCK")" 2>/dev/null; then
    exit 0
fi
echo $$ > "$LOCK"
trap 'rm -f "$LOCK"' EXIT

# --- run with self-diagnosis ---
LOG_DIR="$HOME/Library/Logs/Astro-Nex"
mkdir -p "$LOG_DIR"
LOG="$LOG_DIR/app.log"

if "$PY_BIN" -m astronex >"$LOG" 2>&1; then
    exit 0
fi

# --- failure path: show a native dialog with the error tail, never crash silent ---
RC=$?
ERR="$(tail -n 20 "$LOG" 2>/dev/null)"
osascript -e "display dialog \"Astro-Nex failed to start (exit $RC). See the log at:\\n$LOG\\n\\n$ERR\" with title \"Astro-Nex\" buttons {\"OK\"} default button 1 with icon stop" >/dev/null 2>&1 || true
exit $RC
